{
  "name": "mcp-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for unclecat MCP servers",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build --if-present",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build --if-present && changeset publish"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.3",
      "esbuild": ">=0.28.1"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@eslint/js": "^9.10.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.10.0"
}
