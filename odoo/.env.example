# =============================================================================
# @unclecat/mcp-odoo — connection configuration
# =============================================================================
#
# Pattern:  ODOO_<NAME>_<FIELD>
#
#   <NAME>   uppercase identifier, becomes the lowercase `connection` arg
#            that Claude passes to every tool (e.g. ODOO_PROD_* → "prod").
#   <FIELD>  URL | DB | USERNAME | API_KEY | PASSWORD
#
# Required:  URL, DB, USERNAME, and exactly one of API_KEY / PASSWORD.
# API_KEY is preferred. Create one in Odoo at: Settings → Users → API Keys.
#
# Add as many connections as you like by repeating the block with a new <NAME>.
# =============================================================================

# --- Connection: prod (API key auth, recommended) ---------------------------
ODOO_PROD_URL=https://erp.example.com
ODOO_PROD_DB=production
ODOO_PROD_USERNAME=admin
ODOO_PROD_API_KEY=replace-with-your-api-key
# ODOO_PROD_TIMEOUT_MS=60000   # optional, default 60000, range [1000, 600000]

# --- Connection: staging (password auth, fallback) --------------------------
# Note: users with 2FA enabled cannot authenticate with their password — use an API key.
ODOO_STAGING_URL=https://staging.example.com
ODOO_STAGING_DB=staging
ODOO_STAGING_USERNAME=admin
ODOO_STAGING_PASSWORD=replace-with-your-password

# --- Optional ----------------------------------------------------------------
# MCP_ODOO_LOG_LEVEL=info     # debug | info | warn | error
