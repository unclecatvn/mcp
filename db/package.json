{
  "name": "@unclecat/mcp-multi-db",
  "version": "0.0.1",
  "description": "MCP server for MySQL/MariaDB, PostgreSQL, and SQL Server with parameterized queries, per-alias safety modes, and bilingual docs.",
  "main": "index.js",
  "types": "index.d.ts",
  "type": "module",
  "bin": {
    "mcp-multi-db": "index.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "mcpServer.js",
    "lib/",
    "drivers/",
    "schema/",
    "README.md",
    "README.vi.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example",
    "mcp-db.config.example.json"
  ],
  "scripts": {
    "start": "node index.js",
    "dev": "node --inspect index.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mysql",
    "mariadb",
    "postgresql",
    "sqlserver",
    "database",
    "sql",
    "parameterized-queries"
  ],
  "author": "UncleCat <quangnh.tkcn@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unclecatvn/mcp.git",
    "directory": "db"
  },
  "homepage": "https://github.com/unclecatvn/mcp/tree/master/db#readme",
  "bugs": {
    "url": "https://github.com/unclecatvn/mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mssql": "^10.0.4",
    "mysql2": "^3.6.5",
    "pg": "^8.16.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.1",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
