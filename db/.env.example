# @unclecat/mcp-multi-db — example environment configuration.
# Each alias is defined by DB_<ALIAS>_TYPE plus connection fields.

# === Required ===
DB_PROD_TYPE=postgresql              # mysql | mariadb | postgresql | sqlserver
DB_PROD_URL=postgresql://user:pass@host:5432/dbname
# Or, instead of _URL, set the fields explicitly:
# DB_PROD_HOST=host
# DB_PROD_PORT=5432
# DB_PROD_USER=user
# DB_PROD_PASSWORD=pass
# DB_PROD_DATABASE=dbname

# === Optional, all default-safe ===
DB_PROD_MODE=readonly                # readonly (default) | readwrite | readwrite+ddl
DB_PROD_SSL=prefer                   # disable | prefer (default) | require | verify
# DB_PROD_CA_CERT="-----BEGIN CERTIFICATE-----\n..."  # required when SSL=verify and using a custom CA
DB_PROD_TIMEOUT_MS=30000             # query timeout (default 30000), hard cap 600000
DB_PROD_MAX_ROWS=10000               # row cap (default 10000), hard cap 1000000
DB_PROD_POOL_MAX=5                   # pool max (default 5), hard cap 100

# Example: a separate dev database with write access
# DB_DEV_TYPE=mysql
# DB_DEV_HOST=localhost
# DB_DEV_USER=root
# DB_DEV_PASSWORD=secret
# DB_DEV_DATABASE=appdb
# DB_DEV_MODE=readwrite

# === Server-wide ===
MCP_DB_LOG_LEVEL=info                # debug | info (default) | warn | error
